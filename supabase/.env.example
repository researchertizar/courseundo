# ==========================================================================
# Courseundo — Environment Variables
# Copy this to .env and fill in your values.
# Set these as Supabase Edge Function secrets:
#   supabase secrets set GROQ_API_KEY=xxx
# ==========================================================================

# AI Classification — Primary
GROQ_API_KEY=gsk_your_groq_api_key_here

# AI Embeddings + Classification Fallback
GEMINI_API_KEY=your_gemini_api_key_here

# Email Notifications
RESEND_API_KEY=re_your_resend_api_key_here

# Admin notification recipient
ADMIN_EMAIL=admin@yourdomain.com

# Frontend URL (your GitHub Pages URL)
FRONTEND_URL=https://your-username.github.io/courseundo

# Supabase (auto-set by Supabase runtime, needed for local dev only)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
